---
import Layout from '../layouts/Layout.astro';

const skills = [
  { category: 'Cloud & Infrastructure', items: ['Microsoft Azure', 'Microsoft 365', 'VMware vSphere', 'Hyper-V', 'Netzwerk & Routing', 'Storage-Systeme'] },
  { category: 'Security', items: ['Zero Trust', 'Microsoft Defender', 'MDM / Intune', 'SIEM', 'ISO 27001', 'BSI Grundschutz'] },
  { category: 'IT Management', items: ['ITIL', 'IT-Governance', 'Budgetplanung', 'Vendor Management', 'ITSM / ServiceDesk', 'SLA-Management'] },
  { category: 'Digitalisierung & KI', items: ['Prozessautomatisierung', 'n8n', 'Power Platform', 'SharePoint', 'Microsoft Teams', 'KI-Integration', 'Change Management'] },
  { category: 'Citrix', items: ['Virtual Apps & Desktops', 'Citrix DaaS', 'NetScaler / ADC', 'Web Application Firewall', 'Provisioning Services', 'WEM', 'Citrix Hypervisor', 'UNICON', 'StoreFront'] },
];

const highlights = [
  { year: '2024+', title: 'KI-Transformation', desc: 'Strategische Einführung von KI-gestützten Prozessen und Microsoft Copilot-Integration im Unternehmensalltag.' },
  { year: '2024', title: 'Contract Manager', desc: 'Privat entwickelte Flask-Web-App zur Verwaltung von Verträgen, Immobilien, Fahrzeugen und Budgets – selbst gehostet via Docker.' },
  { year: '2022', title: 'Zero Trust Rollout', desc: 'Vollständige Implementierung einer Zero-Trust-Architektur mit Microsoft Defender und Conditional Access Policies.' },
  { year: '2021', title: 'Cloud-Migration M365', desc: 'Migration der gesamten On-Premise-Infrastruktur in die Microsoft Cloud – ohne Produktionsausfall.' },
  { year: '2019', title: 'IT-Abteilung aufgebaut', desc: 'Team von Grund auf aufgebaut, Prozesse definiert, IT-Governance eingeführt und ITSM etabliert.' },
];
---

<Layout
  title="Über mich – Michael Apitz"
  description="IT-Leiter mit langjähriger Erfahrung in Cloud-Transformation, IT-Security und der Digitalisierung mittelständischer Unternehmen."
>
  <!-- ── INTRO ─────────────────────────────── -->
  <section class="section about-hero">
    <div class="container">
      <div class="about-intro">
        <div class="avatar-wrap fade-up fade-up-1" aria-hidden="true">
          <div class="avatar-ring"></div>
          <div class="avatar"><img src="/avatar.png" alt="Michael Apitz" /></div>
        </div>

        <div class="about-text">
          <p class="section-label fade-up fade-up-1">Über mich</p>
          <h1 class="about-name fade-up fade-up-2">Michael Apitz</h1>
          <p class="about-role fade-up fade-up-2">IT-Leiter · Tech Strategist · Digitalisierungsexperte</p>
          <div class="divider fade-up fade-up-3"></div>
          <p class="about-bio fade-up fade-up-3">
            35 Jahre alt, IT-Leiter bei ibeco-Systems GmbH und seit über einem Jahrzehnt
            gestalte ich IT-Landschaften für mittelständische Unternehmen.
            Meine Leidenschaft liegt in der Schnittstelle zwischen Technologie und Unternehmenstrategie –
            IT nicht als Kostenstelle, sondern als Wettbewerbsvorteil zu positionieren.
          </p>
          <p class="about-bio fade-up fade-up-4" style="margin-top: 1rem;">
            Ich glaube an pragmatische Lösungen, klare Kommunikation und eine Sicherheitskultur,
            die Mitarbeiter befähigt statt einschränkt. Dieses Blog ist mein Weg, Erfahrungen
            weiterzugeben und mit der Community in den Austausch zu treten.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SKILLS ────────────────────────────── -->
  <section class="section section-alt">
    <div class="container">
      <p class="section-label">Technologien & Methoden</p>
      <h2 class="section-title">Skills & Stack</h2>
      <div class="divider"></div>
      <div class="skills-grid">
        {skills.map(group => (
          <div class="card skill-group">
            <h3 class="skill-category">{group.category}</h3>
            <div class="skill-items">
              {group.items.map(item => <span class="skill-item">{item}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── TIMELINE ───────────────────────────── -->
  <section class="section">
    <div class="container">
      <p class="section-label">Karriere</p>
      <h2 class="section-title">Highlights & Meilensteine</h2>
      <div class="divider"></div>
      <ol class="timeline" role="list">
        {highlights.map(item => (
          <li class="timeline-item">
            <div class="timeline-year">{item.year}</div>
            <div class="timeline-dot" aria-hidden="true"></div>
            <div class="card timeline-content">
              <h3 class="timeline-title">{item.title}</h3>
              <p class="timeline-desc">{item.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ── PHILOSOPHY ────────────────────────── -->
  <section class="section section-alt">
    <div class="container">
      <div class="philosophy-box">
        <p class="section-label">Philosophie</p>
        <blockquote class="philosophy-quote">
          „IT ist kein Selbstzweck – sie ist der Enabler für alles, was ein Unternehmen
          erreichen möchte. Mein Job ist es, diese Brücke zu bauen."
        </blockquote>
        <p class="philosophy-author">— M. Apitz, IT-Leiter</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .about-hero { padding-top: 9rem; }

  /* INTRO */
  .about-intro {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3.5rem;
    align-items: start;
  }

  @media (max-width: 720px) {
    .about-intro { grid-template-columns: 1fr; }
  }

  .avatar-wrap {
    position: relative;
    width: 160px; height: 160px;
    flex-shrink: 0;
  }

  .avatar {
    position: relative;
    z-index: 1;
    width: 160px; height: 160px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid rgba(99,102,241,0.3);
  }

  .avatar img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  .avatar-ring {
    position: absolute;
    inset: -5px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, var(--accent), var(--accent-2), var(--accent-3), var(--accent));
    z-index: 0;
    opacity: 0.45;
    animation: spin 9s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .about-name {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    margin-bottom: 0.375rem;
  }

  .about-role {
    color: var(--text-2);
    font-size: 1rem;
    font-weight: 500;
  }

  .about-bio {
    color: var(--text-2);
    font-size: 1rem;
    line-height: 1.8;
    max-width: 640px;
  }

  /* SECTION ALT */
  .section-alt {
    background: linear-gradient(180deg, transparent 0%, rgba(15,23,42,0.5) 15%, rgba(15,23,42,0.5) 85%, transparent 100%);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  /* SKILLS */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .skill-category {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #a5b4fc;
    margin-bottom: 1rem;
  }

  .skill-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-item {
    padding: 0.3125rem 0.75rem;
    border-radius: 8px;
    background: rgba(148, 163, 184, 0.06);
    border: 1px solid var(--border);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-2);
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .skill-item:hover {
    color: var(--text);
    border-color: rgba(99, 102, 241, 0.3);
    background: rgba(99, 102, 241, 0.08);
  }

  /* TIMELINE */
  .timeline {
    list-style: none;
    position: relative;
    margin-top: 2.5rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 130px;
    top: 0; bottom: 0;
    width: 1px;
    background: var(--border);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 130px 16px 1fr;
    gap: 1.5rem;
    align-items: start;
    padding-bottom: 2rem;
  }

  .timeline-year {
    text-align: right;
    font-size: 0.875rem;
    font-weight: 700;
    color: #a5b4fc;
    padding-top: 1.75rem;
  }

  .timeline-dot {
    width: 14px; height: 14px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    margin-top: 1.8125rem;
    flex-shrink: 0;
    box-shadow: 0 0 14px rgba(99, 102, 241, 0.55);
  }

  .timeline-content { margin: 0; }

  .timeline-title {
    font-size: 1.0625rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  .timeline-desc {
    font-size: 0.9375rem;
    color: var(--text-2);
    line-height: 1.7;
  }

  @media (max-width: 580px) {
    .timeline::before  { left: 0; }
    .timeline-item     { grid-template-columns: 14px 1fr; }
    .timeline-year     { display: none; }
  }

  /* PHILOSOPHY */
  .philosophy-box {
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .philosophy-quote {
    font-size: clamp(1.25rem, 2.5vw, 1.875rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.65;
    color: var(--text);
    border: none;
  }

  .philosophy-author {
    color: var(--text-3);
    font-size: 0.9375rem;
    font-weight: 500;
  }
</style>
