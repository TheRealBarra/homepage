---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('altbau');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const statusConfig = {
  'abgeschlossen': { label: 'Abgeschlossen', color: 'green' },
  'in-arbeit':     { label: 'In Arbeit',      color: 'amber' },
  'geplant':       { label: 'Geplant',         color: 'gray'  },
};
const s = statusConfig[entry.data.status];
---

<Layout
  title={`${entry.data.title} – Altbau-Projekt`}
  description={entry.data.description}
>
  <article class="article-wrap">
    <div class="container">
      <header class="article-header">
        <a href="/altbau" class="back-link">← Zurück zum Bautagebuch</a>

        <div class="post-meta">
          <time datetime={entry.data.pubDate.toISOString()}>
            {entry.data.pubDate.toLocaleDateString('de-DE', { month: 'long', year: 'numeric' })}
          </time>
          <span class={`status-badge status-${s.color}`}>{s.label}</span>
          {entry.data.tags?.map(tag => <span class="tag">{tag}</span>)}
        </div>

        <h1 class="article-title">{entry.data.title}</h1>
        <p class="article-desc">{entry.data.description}</p>
      </header>

      <div class="prose">
        <Content />
      </div>

      <footer class="article-footer">
        <a href="/altbau" class="btn btn-secondary">← Alle Einträge</a>
      </footer>
    </div>
  </article>
</Layout>

<style>
  .article-wrap {
    padding-top: 8rem;
    padding-bottom: 5rem;
  }

  .article-header {
    max-width: 780px;
    margin: 0 auto 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  .back-link {
    color: var(--text-3);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 0.25rem;
  }

  .back-link:hover { color: #fbbf24; }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .post-meta time { font-size: 0.8125rem; color: var(--text-3); }

  .status-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.625rem;
    border-radius: 999px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .status-green { background: rgba(34,197,94,0.1);   color: #4ade80; border: 1px solid rgba(34,197,94,0.2); }
  .status-amber { background: rgba(245,158,11,0.1);  color: #fbbf24; border: 1px solid rgba(245,158,11,0.2); }
  .status-gray  { background: rgba(100,116,139,0.1); color: var(--text-3); border: 1px solid var(--border); }

  .article-title {
    font-size: clamp(1.875rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.12;
    color: var(--text);
  }

  .article-desc {
    font-size: 1.125rem;
    color: var(--text-2);
    line-height: 1.75;
  }

  /* PROSE */
  .prose {
    max-width: 780px;
    margin: 0 auto;
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 2.5rem 0 1rem;
    color: var(--text);
  }

  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 2rem 0 0.625rem;
    color: var(--text);
  }

  .prose :global(p) {
    color: var(--text-2);
    font-size: 1.0625rem;
    line-height: 1.85;
    margin-bottom: 1.25rem;
  }

  .prose :global(ul), .prose :global(ol) {
    color: var(--text-2);
    font-size: 1.0625rem;
    line-height: 1.85;
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) { margin-bottom: 0.375rem; }

  .prose :global(strong) { color: var(--text); font-weight: 600; }

  .prose :global(blockquote) {
    border-left: 3px solid #f59e0b;
    padding: 0.875rem 1.375rem;
    margin: 2rem 0;
    background: rgba(245,158,11,0.05);
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .prose :global(blockquote p) {
    margin: 0;
    font-style: italic;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  .article-footer {
    max-width: 780px;
    margin: 3.5rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
</style>
