---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const expertise = [
  { icon: '🏗️', title: 'IT-Infrastruktur', desc: 'Aufbau und Betrieb robuster, skalierbarer IT-Landschaften – On-Premise, Hybrid und Cloud.' },
  { icon: '☁️', title: 'Cloud & Migration', desc: 'Strategische Cloud-Migration mit Azure und Microsoft 365 – sicher, geplant und ohne Produktionsausfall.' },
  { icon: '🔐', title: 'IT-Sicherheit', desc: 'Zero Trust, MDM und proaktive Sicherheitsstrategien für den modernen Unternehmensalltag.' },
  { icon: '🤖', title: 'KI & Automatisierung', desc: 'Einsatz von KI-Tools und Prozessautomatisierung zur spürbaren Effizienzsteigerung im IT-Betrieb.' },
  { icon: '📋', title: 'IT-Governance', desc: 'Strukturierte IT-Prozesse, ITSM und strategische Planung mit klaren Verantwortlichkeiten.' },
  { icon: '👥', title: 'Führung & Mentoring', desc: 'IT-Teams aufbauen, entwickeln und durch technologischen Wandel begleiten.' },
];
---

<Layout>
  <!-- ── HERO ─────────────────────────────── -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>

    <div class="container hero-content">
      <div class="badge fade-up fade-up-1">IT-Leiter · Cloud & Security · Digitalisierung</div>

      <h1 class="hero-title fade-up fade-up-2">
        Praxiswissen aus<br />
        <span class="gradient-text">der IT-Führungsebene</span>
      </h1>

      <p class="hero-desc fade-up fade-up-3">
        Ich bin M. Apitz – IT-Leiter mit langjähriger Erfahrung in IT-Strategie,
        Cloud-Transformation und der Digitalisierung von Unternehmen.
        Hier teile ich mein Wissen offen und praxisnah.
      </p>

      <div class="hero-cta fade-up fade-up-4">
        <a href="/blog" class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
          Zum Blog
        </a>
        <a href="/about" class="btn btn-secondary">Über mich →</a>
      </div>

      <div class="hero-stats fade-up fade-up-5">
        <div class="stat">
          <span class="stat-num">10+</span>
          <span class="stat-label">Jahre IT-Führung</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-num">50+</span>
          <span class="stat-label">Projekte umgesetzt</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-num">∞</span>
          <span class="stat-label">Lernbereitschaft</span>
        </div>
      </div>
    </div>

    <div class="scroll-hint" aria-hidden="true">
      <span>Scroll</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- ── EXPERTISE ──────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Expertise</p>
        <h2 class="section-title">Was ich mitbringe</h2>
        <div class="divider"></div>
        <p class="section-desc">
          Über Jahre gewachsenes Praxiswissen – von der technischen Tiefe bis zur strategischen Ebene.
        </p>
      </div>
      <div class="expertise-grid">
        {expertise.map(item => (
          <div class="card expertise-card">
            <div class="expertise-icon" aria-hidden="true">{item.icon}</div>
            <h3 class="expertise-title">{item.title}</h3>
            <p class="expertise-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── RECENT POSTS ───────────────────────── -->
  {posts.length > 0 && (
    <section class="section section-alt">
      <div class="container">
        <div class="row-header">
          <div>
            <p class="section-label">Blog</p>
            <h2 class="section-title">Neueste Artikel</h2>
            <div class="divider"></div>
          </div>
          <a href="/blog" class="btn btn-secondary">Alle Artikel →</a>
        </div>
        <div class="posts-grid">
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="card post-card">
              <div class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' })}
                </time>
                {post.data.tags?.slice(0, 2).map(tag => <span class="tag">{tag}</span>)}
              </div>
              <h3 class="post-title">{post.data.title}</h3>
              <p class="post-desc">{post.data.description}</p>
              <span class="post-read">Weiterlesen →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── CTA ───────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="cta-box">
        <div class="cta-glow" aria-hidden="true"></div>
        <p class="section-label">Kontakt</p>
        <h2 class="cta-title">Lass uns sprechen</h2>
        <p class="cta-desc">
          Du möchtest dich zu IT-Strategie, Digitalisierung oder Tech-Leadership austauschen?
          Ich freue mich über Vernetzung und fachliche Diskussion.
        </p>
        <a href="mailto:kontakt@example.com" class="btn btn-primary">Nachricht schreiben</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── HERO ───────────────────── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 9rem 0 5rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.12;
  }

  .orb-1 {
    width: 700px; height: 700px;
    background: var(--accent);
    top: -250px; left: -150px;
    animation: drift 14s ease-in-out infinite alternate;
  }

  .orb-2 {
    width: 500px; height: 500px;
    background: var(--accent-2);
    bottom: -180px; right: -100px;
    animation: drift 18s ease-in-out infinite alternate-reverse;
  }

  .orb-3 {
    width: 350px; height: 350px;
    background: var(--accent-3);
    top: 40%; right: 20%;
    animation: drift 22s ease-in-out infinite alternate;
  }

  @keyframes drift {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(30px, 25px) scale(1.08); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.75rem;
  }

  .hero-title {
    font-size: clamp(2.75rem, 6vw, 5.25rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.08;
    color: var(--text);
  }

  .hero-desc {
    font-size: 1.125rem;
    color: var(--text-2);
    max-width: 560px;
    line-height: 1.8;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding: 1.375rem 2rem;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    flex-wrap: wrap;
    backdrop-filter: blur(8px);
  }

  .stat { display: flex; flex-direction: column; }

  .stat-num {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.1;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-3);
    font-weight: 500;
    margin-top: 0.2rem;
  }

  .stat-divider {
    width: 1px; height: 44px;
    background: var(--border);
  }

  .scroll-hint {
    position: absolute;
    bottom: 2.25rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    color: var(--text-3);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    animation: bounce 2.5s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(7px); }
  }

  /* ── EXPERTISE ────────────────── */
  .section-header { margin-bottom: 3rem; }

  .expertise-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .expertise-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    display: block;
  }

  .expertise-title {
    font-size: 1.0625rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .expertise-desc {
    color: var(--text-2);
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  /* ── ALT SECTION ──────────────── */
  .section-alt {
    background: linear-gradient(180deg, transparent 0%, rgba(15,23,42,0.5) 20%, rgba(15,23,42,0.5) 80%, transparent 100%);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .row-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 3rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ── POSTS ────────────────────── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
    gap: 1.5rem;
  }

  .post-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .post-meta time {
    font-size: 0.8rem;
    color: var(--text-3);
  }

  .post-title {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.35;
    color: var(--text);
  }

  .post-desc {
    font-size: 0.9375rem;
    color: var(--text-2);
    line-height: 1.7;
    flex: 1;
  }

  .post-read {
    font-size: 0.875rem;
    font-weight: 600;
    color: #a5b4fc;
    margin-top: 0.25rem;
  }

  /* ── CTA BOX ──────────────────── */
  .cta-box {
    position: relative;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 5rem 3rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    overflow: hidden;
    backdrop-filter: blur(8px);
  }

  .cta-glow {
    position: absolute;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.12) 0%, transparent 70%);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .cta-title {
    font-size: clamp(1.875rem, 3vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    position: relative;
  }

  .cta-desc {
    color: var(--text-2);
    font-size: 1.0625rem;
    max-width: 500px;
    line-height: 1.75;
    position: relative;
  }

  .cta-box .btn { position: relative; }

  @media (max-width: 640px) {
    .hero-stats    { gap: 1.25rem; padding: 1rem 1.25rem; }
    .stat-divider  { display: none; }
    .cta-box       { padding: 2.75rem 1.5rem; }
  }
</style>
