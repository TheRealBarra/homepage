---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Blog – M. Apitz"
  description="Praxisnahe Artikel zu IT-Strategie, Cloud-Technologien, Security und dem Alltag in der IT-Führung."
>
  <section class="blog-header section">
    <div class="container">
      <p class="section-label fade-up fade-up-1">Blog</p>
      <h1 class="section-title fade-up fade-up-2">Wissen &amp; Erfahrungen</h1>
      <div class="divider fade-up fade-up-2"></div>
      <p class="section-desc fade-up fade-up-3">
        Praxisnahe Artikel zu IT-Strategie, Cloud, Security und dem Alltag
        in der IT-Führung – direkt aus der Praxis.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top: 1rem;">
    <div class="container">
      {posts.length === 0 ? (
        <p class="empty-state">Noch keine Artikel veröffentlicht – bald geht's los!</p>
      ) : (
        <div class="blog-grid">
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="card blog-card">
              <div class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' })}
                </time>
                {post.data.tags?.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
              </div>
              <h2 class="blog-card-title">{post.data.title}</h2>
              <p class="blog-card-desc">{post.data.description}</p>
              <span class="post-read">Weiterlesen →</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .blog-header { padding-top: 9rem; padding-bottom: 1rem; }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .blog-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .post-meta time {
    font-size: 0.8rem;
    color: var(--text-3);
  }

  .blog-card-title {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.35;
    color: var(--text);
  }

  .blog-card-desc {
    font-size: 0.9375rem;
    color: var(--text-2);
    line-height: 1.7;
    flex: 1;
  }

  .post-read {
    font-size: 0.875rem;
    font-weight: 600;
    color: #a5b4fc;
    margin-top: 0.25rem;
  }

  .empty-state {
    color: var(--text-2);
    font-size: 1.0625rem;
    text-align: center;
    padding: 5rem 0;
  }
</style>
