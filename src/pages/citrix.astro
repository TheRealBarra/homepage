---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';

const citrixPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft && p.data.tags?.some(t => t === 'Citrix'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const stack = [
  {
    icon: 'device-desktop',
    title: 'Virtual Apps & Desktops',
    desc: 'Design, Sizing und Betrieb von CVAD-Umgebungen – On-Premise, Hybrid und als DaaS. Von der Pilotinstallation bis zur Enterprise-Skalierung.',
  },
  {
    icon: 'cloud',
    title: 'Citrix DaaS',
    desc: 'Cloud-Delivery von Desktops und Applikationen mit Citrix DaaS. Migration von On-Premise CVAD in die Cloud – inkl. Identitäts- und Policy-Konzepten.',
  },
  {
    icon: 'network',
    title: 'NetScaler / ADC',
    desc: 'Load Balancing, SSL Offloading, Gateway-Konfiguration und High Availability. Citrix ADC als zentraler Eintrittspunkt für sichere App-Delivery.',
  },
  {
    icon: 'shield-check',
    title: 'Web Application Firewall',
    desc: 'Absicherung von Web-Applikationen mit der NetScaler WAF. Schutz gegen OWASP Top 10, Bot-Traffic-Kontrolle und SSL Inspection.',
  },
  {
    icon: 'database',
    title: 'Provisioning Services',
    desc: 'Streaming-basierte VDA-Bereitstellung mit PVS. Write-Cache-Strategien, vDisk-Management und Target Device Lifecycle in großen Umgebungen.',
  },
  {
    icon: 'settings',
    title: 'Workspace Environment Management',
    desc: 'WEM als Ersatz für GPO-basierte Logon-Optimierung. CPU/RAM-Verwaltung, Application Security und schnelle Logon-Zeiten in multi-user Szenarien.',
  },
  {
    icon: 'layers-intersect',
    title: 'Citrix Hypervisor',
    desc: 'Bare-Metal-Virtualisierung mit Citrix Hypervisor (XenServer). Management über XenCenter und Integration in Citrix CVAD Machine Catalogs.',
  },
  {
    icon: 'terminal',
    title: 'UniconOS (ehem. eLux)',
    desc: 'Lightweight Linux-Endpoint-OS für Citrix-Umgebungen. Hardware repurposing, Boot-to-DaaS und zentrale Verwaltung mit UniconOS Management.',
  },
];

const highlights = [
  { label: 'Jahre Citrix-Erfahrung', value: '15+' },
  { label: 'CVAD-Umgebungen betreut', value: '40+' },
  { label: 'VDA-Nodes verwaltet', value: '500+' },
  { label: 'NetScaler-Instanzen', value: '20+' },
];
---

<Layout
  title="Citrix Expertise – M. Apitz"
  description="15+ Jahre Citrix-Erfahrung: Virtual Apps & Desktops, NetScaler, DaaS, WEM, Provisioning Services und UniconOS. Praxiswissen aus dem Unternehmensalltag."
>
  <!-- ── HERO ─────────────────────────────── -->
  <section class="citrix-hero hero-section">
    <div class="hero-bg" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
    </div>
    <div class="container">
      <div class="hero-content">
        <div class="citrix-badge fade-up fade-up-1">
          <span class="badge-dot" aria-hidden="true"></span>
          15+ Jahre Citrix-Expertise
        </div>
        <h1 class="hero-title fade-up fade-up-2">
          Citrix.<br />
          <span class="gradient-text">Von Grund auf.</span>
        </h1>
        <p class="hero-desc fade-up fade-up-3">
          Seit über 15 Jahren plane, implementiere und betreibe ich Citrix-Umgebungen
          unterschiedlichster Größe. Von der ersten XenApp-Installation bis zum modernen
          DaaS-Rollout mit UniconOS-Endpoints – hier ist mein Wissen gebündelt.
        </p>
        <div class="hero-stats fade-up fade-up-4">
          {highlights.map(h => (
            <div class="stat">
              <span class="stat-num">{h.value}</span>
              <span class="stat-label">{h.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── STACK GRID ─────────────────────────── -->
  <section class="section">
    <div class="container">
      <p class="section-label">Technologie-Stack</p>
      <h2 class="section-title">Was ich beherrsche</h2>
      <div class="divider"></div>
      <p class="section-desc">
        Kein Überblicks-Wissen – sondern Praxiserfahrung aus echten Projekten,
        unter echtem Produktionsdruck.
      </p>
      <div class="stack-grid">
        {stack.map(item => (
          <div class="card stack-card">
            <div class="stack-icon"><Icon name={item.icon} size={26} /></div>
            <h3 class="stack-title">{item.title}</h3>
            <p class="stack-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PHILOSOPHY ─────────────────────────── -->
  <section class="section section-alt">
    <div class="container">
      <div class="philosophy-grid">
        <div class="philosophy-text">
          <p class="section-label">Mein Ansatz</p>
          <h2 class="section-title">Citrix ist kein Produkt.<br />Es ist eine Disziplin.</h2>
          <div class="divider"></div>
          <p class="body-text">
            Citrix-Projekte scheitern selten an der Technologie – sie scheitern an
            unterschätzter Komplexität, schlechtem Sizing oder fehlender Strategie für
            den Betrieb. In 15 Jahren habe ich alle Fehler gesehen, die es zu sehen gibt.
            Und viele selbst gemacht.
          </p>
          <p class="body-text">
            Was ich gelernt habe: Eine gute Citrix-Umgebung fällt niemandem auf.
            Sie funktioniert einfach. Nutzer booten, Apps öffnen, Arbeit passiert.
            Dafür braucht man kein Produkt-Feature-Bingo – man braucht solides
            Engineering, durchdachte Policies und einen Betriebsprozess, der skaliert.
          </p>
        </div>
        <div class="philosophy-stats">
          <div class="philo-card card">
            <span class="philo-icon"><Icon name="target" size={22} /></span>
            <h3>Sizing first</h3>
            <p>Schlechtes Sizing ist die häufigste Ursache für Performance-Probleme. Bevor ein VDA deployed wird, steht das Ressourcenkonzept.</p>
          </div>
          <div class="philo-card card">
            <span class="philo-icon"><Icon name="settings" size={22} /></span>
            <h3>Image-Disziplin</h3>
            <p>Saubere Master-Images, PVS-Workflows und WEM-Policies sind kein Overhead – sie sind die Basis für wartbaren Betrieb.</p>
          </div>
          <div class="philo-card card">
            <span class="philo-icon"><Icon name="chart-bar" size={22} /></span>
            <h3>Monitoring eingebaut</h3>
            <p>Citrix Director, SCOM-Integration und NetScaler Insights sind Pflicht, keine Kür. Man muss sehen, was passiert.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── BLOG POSTS ─────────────────────────── -->
  {citrixPosts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="row-header">
          <div>
            <p class="section-label">Blog</p>
            <h2 class="section-title">Citrix-Artikel</h2>
            <div class="divider"></div>
          </div>
          <a href="/blog" class="btn btn-secondary">Alle Artikel →</a>
        </div>
        <div class="posts-grid">
          {citrixPosts.map(post => (
            <a href={`/blog/${post.id}`} class="card post-card">
              <div class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' })}
                </time>
                {post.data.tags?.filter(t => t !== 'Citrix').slice(0, 2).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <h3 class="post-title">{post.data.title}</h3>
              <p class="post-desc">{post.data.description}</p>
              <span class="post-read">Weiterlesen →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── CTA ───────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="cta-box">
        <div class="cta-glow" aria-hidden="true"></div>
        <p class="section-label">Austausch</p>
        <h2 class="cta-title">Citrix-Themen besprechen</h2>
        <p class="cta-desc">
          Du planst eine CVAD-Migration, kämpfst mit NetScaler-Konfiguration
          oder fragst dich, ob UniconOS das Richtige für deine Umgebung ist?
          Ich helfe gerne mit Praxiserfahrung.
        </p>
        <a href="mailto:kontakt@example.com" class="btn btn-primary">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── HERO ─────────────────────── */
  .hero-section {
    min-height: 80vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 9rem 0 5rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.11;
  }

  .orb-1 {
    width: 600px; height: 600px;
    background: var(--accent);
    top: -200px; left: -100px;
    animation: drift 14s ease-in-out infinite alternate;
  }

  .orb-2 {
    width: 450px; height: 450px;
    background: var(--accent-3);
    bottom: -150px; right: -80px;
    animation: drift 18s ease-in-out infinite alternate-reverse;
  }

  @keyframes drift {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(30px, 25px) scale(1.08); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 760px;
  }

  .citrix-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 1rem;
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    background: rgba(6, 182, 212, 0.1);
    color: #67e8f9;
    border: 1px solid rgba(6, 182, 212, 0.22);
    width: fit-content;
  }

  .badge-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #06b6d4;
    box-shadow: 0 0 8px #06b6d4;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  .hero-title {
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.08;
    color: var(--text);
  }

  .hero-desc {
    font-size: 1.125rem;
    color: var(--text-2);
    line-height: 1.8;
    max-width: 580px;
  }

  .hero-stats {
    display: flex;
    gap: 0;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    width: fit-content;
    backdrop-filter: blur(8px);
  }

  .stat {
    display: flex;
    flex-direction: column;
    padding: 1.25rem 2rem;
    border-right: 1px solid var(--border);
  }

  .stat:last-child { border-right: none; }

  .stat-num {
    font-size: 1.875rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, var(--accent), var(--accent-3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.1;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-3);
    font-weight: 500;
    margin-top: 0.2rem;
    white-space: nowrap;
  }

  /* ── STACK GRID ───────────────── */
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .stack-icon {
    width: 2.25rem; height: 2.25rem;
    margin-bottom: 0.875rem;
    display: flex; align-items: center;
    color: var(--accent);
  }

  .stack-title {
    font-size: 1.0625rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .stack-desc {
    font-size: 0.9375rem;
    color: var(--text-2);
    line-height: 1.7;
  }

  /* ── ALT SECTION ──────────────── */
  .section-alt {
    background: linear-gradient(180deg, transparent 0%, rgba(15,23,42,0.5) 15%, rgba(15,23,42,0.5) 85%, transparent 100%);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  /* ── PHILOSOPHY ───────────────── */
  .philosophy-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .philosophy-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  .body-text {
    color: var(--text-2);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .philosophy-stats {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .philo-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .philo-icon { width: 1.5rem; height: 1.5rem; display: flex; align-items: center; color: var(--accent); }

  .philo-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }

  .philo-card p {
    font-size: 0.9rem;
    color: var(--text-2);
    line-height: 1.65;
  }

  /* ── ROW HEADER ───────────────── */
  .row-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 3rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ── POSTS ────────────────────── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
    gap: 1.5rem;
  }

  .post-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .post-meta time { font-size: 0.8rem; color: var(--text-3); }

  .post-title {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.35;
    color: var(--text);
  }

  .post-desc {
    font-size: 0.9375rem;
    color: var(--text-2);
    line-height: 1.7;
    flex: 1;
  }

  .post-read {
    font-size: 0.875rem;
    font-weight: 600;
    color: #a5b4fc;
    margin-top: 0.25rem;
  }

  /* ── CTA ──────────────────────── */
  .cta-box {
    position: relative;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 5rem 3rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    overflow: hidden;
    backdrop-filter: blur(8px);
  }

  .cta-glow {
    position: absolute;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(6, 182, 212, 0.1) 0%, transparent 70%);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .cta-title {
    font-size: clamp(1.875rem, 3vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    position: relative;
  }

  .cta-desc {
    color: var(--text-2);
    font-size: 1.0625rem;
    max-width: 520px;
    line-height: 1.75;
    position: relative;
  }

  .cta-box .btn { position: relative; }

  @media (max-width: 640px) {
    .hero-stats { flex-direction: column; width: 100%; }
    .stat { border-right: none; border-bottom: 1px solid var(--border); }
    .stat:last-child { border-bottom: none; }
    .cta-box { padding: 2.75rem 1.5rem; }
  }
</style>
